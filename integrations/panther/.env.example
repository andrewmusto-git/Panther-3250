# ============================================================
# Panther → Veza OAA Integration — Environment Configuration
# Copy this file to .env and populate all required values.
# NEVER commit the .env file — it contains secrets.
# ============================================================

# ------------------------------------------------------------
# Panther OAuth2 Connection Settings
# Grant type: client_credentials
# ------------------------------------------------------------

# Panther API base URL — set this to the exact base URL for your deployment.
# Do NOT include a trailing slash. Include any path prefix your instance requires
# (e.g. /v1 for SaaS Panther SIEM, or no prefix for self-hosted instances).
# SaaS example       : https://api.mycompany.runpanther.net/v1
# Self-hosted example: https://panther.internal.example.com
PANTHER_BASE_URL=https://your-panther-api-host.runpanther.net

# OAuth2 token endpoint provided by your identity provider
# Cognito example : https://myco.auth.us-east-1.amazoncognito.com/oauth2/token
# Okta example    : https://myco.okta.com/oauth2/default/v1/token
PANTHER_TOKEN_URL=https://your-idp.auth.us-east-1.amazoncognito.com/oauth2/token

# OAuth2 client ID issued for this integration
PANTHER_CLIENT_ID=your_client_id_here

# OAuth2 client secret (keep secret; never commit this file)
PANTHER_CLIENT_SECRET=your_client_secret_here

# OAuth2 scope — leave empty if your IdP does not require a scope value
# Example: panther:api   or   openid profile
PANTHER_SCOPE=panther:api

# Tenant ID sent as the 'tenant' HTTP request header on all Panther API calls
# This value is instance-specific — change it to match your deployment
PANTHER_TENANT=3250

# ------------------------------------------------------------
# Veza Configuration
# ------------------------------------------------------------

# Veza instance URL (include https://, exclude trailing slash)
VEZA_URL=https://your-company.veza.com

# Veza API key — generated in Veza Console → Settings → API Keys
VEZA_API_KEY=your_veza_api_key_here

# ------------------------------------------------------------
# OAA Provider Settings (optional overrides)
# ------------------------------------------------------------
# Uncomment to override the defaults used by panther.py

# PROVIDER_NAME=Panther
# DATASOURCE_NAME=panther-prod
